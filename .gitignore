data/raw/*

# Índices generados por el programa
data/index/*

# Permitir que las carpetas existan en git
!data/raw/.gitkeep
!data/index/.gitkeep

# Archivos temporales
*.tmp
*.log

# Carpeta de build si se usa
build/

